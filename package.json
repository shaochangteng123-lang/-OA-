{
  "name": "yulilog-worklog-system",
  "version": "1.0.0",
  "description": "工作日志管理系统 - 北京基础设施项目管理平台",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite --port 8899",
    "dev:server": "tsx watch server/index.ts",
    "build": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "start": "node dist/server/index.js",
    "lint": "eslint . --ext .vue,.js,.ts,.jsx,.tsx",
    "lint:fix": "eslint . --ext .vue,.js,.ts,.jsx,.tsx --fix",
    "format": "prettier --write \"**/*.{js,ts,vue,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,vue,json,css,scss,md}\"",
    "type-check": "vue-tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "jest --watch",
    "test:ui": "jest --watch",
    "test:run": "jest",
    "test:coverage": "jest --coverage",
    "quality:check": "npm run lint && npm run type-check && npm run format:check",
    "quality:fix": "npm run format && npm run lint:fix",
    "check:env": "node scripts/check-env.js",
    "update:holidays": "tsx server/scripts/update-holidays.ts",
    "create:admin": "tsx server/scripts/create-admin.ts",
    "clear:reimbursement": "tsx server/scripts/clear-reimbursement-data.ts",
    "prepare": "husky",
    "docker": "./docker-quick-start.sh",
    "docker:quick": "./docker-quick-start.sh",
    "docker:start": "./docker-start.sh",
    "docker:stop": "./docker-stop.sh",
    "docker:logs": "./docker-logs.sh",
    "docker:restart": "docker compose down && docker compose up -d --build",
    "docker:build": "docker compose build --no-cache",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:dev": "docker compose -f docker-compose.dev.yml up -d",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:dev:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "mode:dev": "bash scripts/switch-mode.sh dev",
    "mode:prod": "bash scripts/switch-mode.sh prod",
    "mode:check": "bash scripts/check-mode.sh"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@notionhq/client": "^5.6.0",
    "@tanstack/vue-query": "^5.28.4",
    "@tiptap/extension-bold": "^3.14.0",
    "@tiptap/extension-code": "^3.14.0",
    "@tiptap/extension-code-block-lowlight": "^3.14.0",
    "@tiptap/extension-color": "^3.14.0",
    "@tiptap/extension-highlight": "^3.14.0",
    "@tiptap/extension-italic": "^3.14.0",
    "@tiptap/extension-link": "^3.14.0",
    "@tiptap/extension-placeholder": "^3.14.0",
    "@tiptap/extension-task-item": "^3.14.0",
    "@tiptap/extension-task-list": "^3.14.0",
    "@tiptap/extension-text-align": "^3.14.0",
    "@tiptap/extension-text-style": "^3.14.0",
    "@tiptap/extension-typography": "^3.14.0",
    "@tiptap/extension-underline": "^3.14.0",
    "@tiptap/starter-kit": "^3.14.0",
    "@tiptap/vue-3": "^3.14.0",
    "@types/archiver": "^7.0.0",
    "archiver": "^7.0.1",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "better-sqlite3-session-store": "^0.1.0",
    "cors": "^2.8.5",
    "date-fns": "^3.3.1",
    "dotenv": "^16.4.5",
    "element-plus": "^2.6.2",
    "express": "^4.18.3",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.0",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "lowlight": "^3.3.0",
    "multer": "^2.0.2",
    "nanoid": "^5.0.6",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdf2pic": "^3.2.0",
    "pinia": "^2.1.7",
    "rrule": "^2.8.1",
    "sharp": "^0.33.5",
    "tesseract.js": "^7.0.0",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "vuedraggable": "^4.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.11.25",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/vue3-jest": "^29.2.6",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.6.2",
    "happy-dom": "^20.0.11",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jscpd": "^4.0.5",
    "jsdom": "^27.3.0",
    "lint-staged": "^16.2.7",
    "madge": "^8.0.0",
    "prettier": "^3.7.4",
    "sass-embedded": "^1.98.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2",
    "typescript-eslint": "^8.50.0",
    "unplugin-auto-import": "^0.17.5",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^5.1.6",
    "vue-tsc": "^2.0.6"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.5.0"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md}": [
      "prettier --write"
    ]
  }
}
