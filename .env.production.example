# ============================================
# YuliLog 宸ヤ綔鏃ュ織绯荤粺 - 鐜鍙橀噺閰嶇疆
# ============================================
# 浣跨敤鏂规硶锛?
# 1. 澶嶅埗姝ゆ枃浠朵负 .env.production
# 2. 濉啓浠ヤ笅閰嶇疆淇℃伅
# 3. 淇濆瓨鍚庨噸鍚湇鍔?
# ============================================

# 搴旂敤閰嶇疆
NODE_ENV=production
PORT=8899
FRONTEND_URL=http://localhost:8899

# 鏁版嵁搴撻厤缃?
DATABASE_PATH=./data/worklog.db

# 浼氳瘽瀵嗛挜锛堝繀椤昏嚦灏?2涓瓧绗︼紝鐢熶骇鐜璇蜂慨鏀癸紒锛?
SESSION_SECRET=yulilog_worklog_system_session_secret_key_2025_change_me_in_production

# 飞书配置（可选，用于日历提醒功能）
# 如需使用飞书日历提醒功能，请到飞书开放平台创建应用：
# https://open.feishu.cn/app
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# Docker 閰嶇疆锛堝彲閫夛級
HOST_PORT=8899

# 百度OCR配置（可选，用于发票识别）
# 请到百度AI开放平台创建应用并获取以下信息：
# https://ai.baidu.com/tech/ocr_receipts/vatinvoice
BAIDU_OCR_API_KEY=your_baidu_ocr_api_key
BAIDU_OCR_SECRET_KEY=your_baidu_ocr_secret_key

# 腾讯云OCR配置（可选，备用方案）
# 请到腾讯云控制台获取以下信息：
# https://console.cloud.tencent.com/cam/capi
TENCENT_SECRET_ID=your_tencent_secret_id
TENCENT_SECRET_KEY=your_tencent_secret_key
