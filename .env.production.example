# ============================================
# YuliLog 宸ヤ綔鏃ュ織绯荤粺 - 鐜鍙橀噺閰嶇疆
# ============================================
# 浣跨敤鏂规硶锛?
# 1. 澶嶅埗姝ゆ枃浠朵负 .env.production
# 2. 濉啓浠ヤ笅閰嶇疆淇℃伅
# 3. 淇濆瓨鍚庨噸鍚湇鍔?
# ============================================

# 搴旂敤閰嶇疆
NODE_ENV=production
PORT=8899
FRONTEND_URL=http://localhost:8899

# 鏁版嵁搴撻厤缃?
DATABASE_PATH=./data/worklog.db

# 浼氳瘽瀵嗛挜锛堝繀椤昏嚦灏?2涓瓧绗︼紝鐢熶骇鐜璇蜂慨鏀癸紒锛?
SESSION_SECRET=yulilog_worklog_system_session_secret_key_2025_change_me_in_production

# 椋炰功 OAuth 閰嶇疆
# 璇峰埌椋炰功寮€鏀惧钩鍙板垱寤哄簲鐢ㄥ苟鑾峰彇浠ヤ笅淇℃伅锛?
# https://open.feishu.cn/app
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_REDIRECT_URI=http://localhost:8899/api/auth/feishu/callback

# Docker 閰嶇疆锛堝彲閫夛級
HOST_PORT=8899
