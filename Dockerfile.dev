# ============================================
# YuliLog 工作日志系统 - 开发环境 Dockerfile
# ============================================
# 开发模式：支持热重载、源码挂载、OCR 功能
# ============================================

FROM node:20-bookworm

# 配置 Debian 镜像源（使用阿里云镜像）
RUN sed -i 's/deb.debian.org/mirrors.aliyun.com/g' /etc/apt/sources.list.d/debian.sources && \
    sed -i 's/security.debian.org/mirrors.aliyun.com/g' /etc/apt/sources.list.d/debian.sources

# 安装 Python 和 OCR 依赖
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-venv \
    poppler-utils \
    fonts-noto-cjk \
    libgl1-mesa-glx \
    && rm -rf /var/lib/apt/lists/*

# 配置 pip 使用阿里云镜像
RUN pip3 config set global.index-url https://mirrors.aliyun.com/pypi/simple/ \
    && pip3 config set global.trusted-host mirrors.aliyun.com

# 安装 PaddleOCR
RUN pip3 install --break-system-packages paddlepaddle paddleocr

# 配置 npm 镜像源
RUN npm config set registry https://registry.npmmirror.com

WORKDIR /app

# 复制 package 文件
COPY package.json package-lock.json ./

# 安装 npm 依赖
RUN npm config set fetch-retries 5 && \
    npm config set fetch-retry-mintimeout 20000 && \
    npm config set fetch-retry-maxtimeout 120000 && \
    npm ci --legacy-peer-deps

# 复制 OCR worker 脚本（源码挂载会覆盖 server 目录，但构建阶段先放好）
COPY server/scripts/paddle_ocr_worker.py ./server/scripts/

# 暴露端口
EXPOSE 8899 3000

# 启动开发服务器
CMD ["npm", "run", "dev"]
